rm(list = ls())
setwd("~/")
# Set beta to shape the ROC curve
beta <- 0.31
# Generate FPR values (from 0 to 1)
fpr <- seq(0, 1, length.out = 1000)
tpr <- fpr^beta  # Idealized TPR
# Calculate AUC using trapezoidal rule
auc <- sum(diff(fpr) * (head(tpr, -1) + tail(tpr, -1)) / 2)
pdf("roc.pdf", width = 5, height = 5)
# Plot the ROC curve
plot(NA, xlim = c(0, 1), ylim = c(0, 1),
xlab = "False Positive Rate", ylab = "True Positive Rate",
main = paste("ROC Curve (AUC =", round(auc, 2), ")"),
frame = F)
grid(lty = 1)
lines(fpr, tpr, col = "black", lwd = 2)
# Add diagonal (random classifier)
abline(0, 1, col = "gray", lty = 2)
# Annotate AUC
text(0.6, 0.2, labels = paste("AUC ≈", round(auc, 2)), cex = 1.2)
dev.off()
