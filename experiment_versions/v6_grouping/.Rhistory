library(igraph)
library(ggplot2)
set.seed(42)
g <- erdos.renyi.game(50, p = 0.08)
deg <- degree(g)
deg_df <- as.data.frame(table(deg))
deg_df$deg <- as.integer(as.character(deg_df$deg))
par(mfrow = c(1, 2))
plot(g,
vertex.size = 6,
vertex.label = NA,
vertex.color = "steelblue",
edge.color = "gray50",
main = "Random Network (Erdos-Renyi, n=50, p=0.08)")
barplot(deg_df$Freq,
names.arg = deg_df$deg,
xlab = "Degree",
ylab = "Count",
main = "Degree Distribution",
col = "steelblue",
border = "white")
