summarise(diff_switches = mean(diff(onset))) %>%
mutate(fixation = ifelse(n_mqs == 1, FALSE, fixation),
cond = as.factor(paste(freq, n_mqs, fixation, sep = "_")),
n_mqs = as.factor(n_mqs)) %>%
