y <- c(1, 2, 1, 3, 2, 4, 2, 5, 3, 5)
# Fit a true 10th-degree polynomial
fit <- lm(y ~ poly(x, 10, raw=TRUE))
# Extract coefficients
coefs <- coefficients(fit)
# Create a dense x sequence for smooth plotting
x_dense <- seq(min(x), max(x), length.out=500)
# Evaluate the polynomial manually using its coefficients
y_dense <- rep(0, length(x_dense))
for (i in 0:10) {
y_dense <- y_dense + coefs[i+1] * x_dense^i
}
# Plot original points
plot(x, y, pch=19, main="10th-order Polynomial via Coefficients")
# Add the polynomial curve
lines(x_dense, y_dense, col="red", lwd=2)
# Add the polynomial curve
lines(x_dense, y_dense, col="red", lwd=2)
